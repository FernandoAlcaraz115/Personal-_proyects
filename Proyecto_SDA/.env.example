# Copy this file to .env and fill in your values

# OpenAI (leave empty if not using)
OPENAI_API_KEY=

# Google Gemini (leave empty if not using)
GEMINI_API_KEY=

# Serper (optional, for future Google Search verification)
SERPER_API_KEY=

# Ollama (default: local instance)
OLLAMA_BASE_URL=http://localhost:11434
DEFAULT_MODEL=llama3
DEFAULT_LLM_PROVIDER=ollama
